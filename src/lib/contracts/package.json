{
    "name": "@dotdm/contracts",
    "version": "1.1.1",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./abi": {
            "types": "./dist/abi.d.ts",
            "import": "./dist/abi.js"
        }
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup src/index.ts src/abi.ts --format esm --dts --clean",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@dotdm/env": "workspace:*",
        "@dotdm/utils": "workspace:*",
        "@noble/hashes": "catalog:",
        "@polkadot-apps/bulletin": "catalog:",
        "@polkadot-apps/chain-client": "catalog:",
        "@polkadot-apps/contracts": "catalog:",
        "@polkadot-apps/descriptors": "catalog:",
        "@polkadot-apps/tx": "catalog:",
        "multiformats": "catalog:",
        "polkadot-api": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    }
}
