{
    "name": "@parity/cdm-env",
    "version": "2.0.6",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./registry": {
            "types": "./dist/registry.d.ts",
            "import": "./dist/registry.js"
        }
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup src/index.ts src/registry.ts --format esm --dts --clean",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@parity/cdm-utils": "workspace:*",
        "@parity/product-sdk-descriptors": "catalog:",
        "@parity/product-sdk-host": "catalog:",
        "@polkadot-labs/hdkd": "catalog:",
        "@polkadot-labs/hdkd-helpers": "catalog:",
        "polkadot-api": "catalog:",
        "smoldot": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    }
}
