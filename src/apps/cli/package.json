{
    "name": "@parity/cdm-cli",
    "version": "0.8.24",
    "private": true,
    "type": "module",
    "bin": {
        "cdm": "./src/cli.ts"
    },
    "scripts": {
        "dev": "bun run src/cli.ts",
        "build": "echo 'No build needed - bun runs TypeScript directly'",
        "compile": "bun build --compile src/cli.ts --outfile dist/cdm",
        "test": "vitest run",
        "embed-templates": "bun run ../../lib/scripts/embed-templates.ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@parity/cdm-codegen": "workspace:*",
        "@parity/cdm-builder": "workspace:*",
        "@parity/cdm-env": "workspace:*",
        "@parity/cdm-utils": "workspace:*",
        "@parity/product-sdk-contracts": "catalog:",
        "@parity/product-sdk-tx": "catalog:",
        "commander": "catalog:",
        "ink": "catalog:",
        "polkadot-api": "catalog:",
        "react": "catalog:",
        "react-devtools-core": "file:../../stubs/react-devtools-core",
        "supports-hyperlinks": "catalog:"
    },
    "devDependencies": {
        "@types/bun": "catalog:",
        "@types/react": "catalog:",
        "typescript": "catalog:"
    }
}
